# POSIX command example:
# command = "<project-root>/.agent-index/.venv/bin/python"
# Windows command example:
# command = "<project-root>/.agent-index/.venv/Scripts/python.exe"

[mcp_servers.gitnexus]
command = "<agent-index-python>"
args = ["<project-root>/.agent-index/bin/agent-index.py", "provider", "gitnexus", "mcp"]

[mcp_servers.codegraph]
command = "<agent-index-python>"
args = ["<project-root>/.agent-index/bin/agent-index.py", "provider", "codegraph", "mcp"]
